# Supabase (Settings → API en el dashboard)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# URL pública del frontend (opcional)
VITE_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Variables para edge functions (configuralas en Supabase Dashboard) ---
# AI_GATEWAY_URL   Endpoint compatible OpenAI (ej. https://api.openai.com/v1/chat/completions)
# AI_API_KEY       API key del proveedor de IA
# AI_CHAT_MODEL    Modelo del agente (ej. gpt-4o-mini)
# AI_IMAGE_MODEL   Modelo de edición de imágenes
# MANYCHAT_API_KEY Opcional
